{
  "name": "@cockpit/cli",
  "version": "0.0.1",
  "description": "Cockpit CLI - AI-first Development Environment Orchestrator",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "cockpit": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cockpit/adapters": "workspace:*",
    "@cockpit/core": "workspace:*",
    "@cockpit/skills": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
